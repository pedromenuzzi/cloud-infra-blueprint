############################################
# Cloud Infra Blueprint - .env.example
# Copy to .env and fill in real values.
# NEVER commit .env files with real secrets.
############################################

# ---- Core ----
NODE_ENV=development
LOG_LEVEL=info

# ---- Frontend (apps/web) ----
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# ---- Backend (apps/api) ----
API_PORT=3000
FRONTEND_URL=http://localhost:5173

# ---- Database (Postgres) ----
# Use the docker-compose default for local dev:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blueprint?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Auth (Clerk OR Auth.js) ----
# Pick ONE. Default in code is Clerk; Auth.js is feature-flagged.
AUTH_PROVIDER=clerk
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Auth.js (alternative)
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ---- Realtime (Yjs WebSocket) ----
WS_JWT_SECRET=change-me-32-bytes-base64

# ---- Object storage (Cloudflare R2 / S3-compatible) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cloud-blueprint-exports
R2_PUBLIC_URL=

# ---- Git integrations ----
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITLAB_OAUTH_CLIENT_ID=
GITLAB_OAUTH_CLIENT_SECRET=

# ---- Encryption (for stored git tokens) ----
# 32 bytes base64 (use: openssl rand -base64 32)
ENCRYPTION_KEY=

# ---- Observability ----
SENTRY_DSN=
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
