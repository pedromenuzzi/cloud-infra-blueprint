{
  "name": "@blueprint/ui",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Shared design-system primitives (Button, Card, Input, ...) built on Tailwind + shadcn conventions.",
  "keywords": [
    "react",
    "design-system",
    "tailwindcss",
    "shadcn",
    "ui-components",
    "cloud-blueprint"
  ],
  "homepage": "https://github.com/cloud-blueprint/cloud-blueprint/tree/main/packages/ui#readme",
  "bugs": {
    "url": "https://github.com/cloud-blueprint/cloud-blueprint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloud-blueprint/cloud-blueprint.git",
    "directory": "packages/ui"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "files": [
    "src",
    "tailwind-preset.cjs"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf .turbo"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4"
  },
  "devDependencies": {
    "@blueprint/config": "workspace:*",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4"
  }
}
