{
  "name": "@blueprint/ir",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "Canonical Intermediate Representation for Cloud Infra Blueprint. Single source of truth shared by canvas and HCL editor.",
  "keywords": [
    "terraform",
    "hcl",
    "infrastructure-as-code",
    "intermediate-representation",
    "iac",
    "cloud-blueprint"
  ],
  "homepage": "https://github.com/cloud-blueprint/cloud-blueprint/tree/main/packages/ir#readme",
  "bugs": {
    "url": "https://github.com/cloud-blueprint/cloud-blueprint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloud-blueprint/cloud-blueprint.git",
    "directory": "packages/ir"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "blueprint:source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@blueprint/config": "workspace:*",
    "@types/node": "^20.14.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}
