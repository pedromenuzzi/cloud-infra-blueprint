{
  "name": "@blueprint/hcl",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "HCL parser and emitter for Cloud Infra Blueprint. Wraps @cdktf/hcl2json (WASM) for parsing and ships a custom emitter that preserves trivia for minimal-patch round-trips.",
  "keywords": [
    "terraform",
    "hcl",
    "parser",
    "emitter",
    "wasm",
    "cdktf",
    "infrastructure-as-code",
    "cloud-blueprint"
  ],
  "homepage": "https://github.com/cloud-blueprint/cloud-blueprint/tree/main/packages/hcl#readme",
  "bugs": {
    "url": "https://github.com/cloud-blueprint/cloud-blueprint/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloud-blueprint/cloud-blueprint.git",
    "directory": "packages/hcl"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "blueprint:source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./worker": {
      "blueprint:source": "./src/worker.ts",
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js",
      "default": "./dist/worker.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@blueprint/ir": "workspace:*",
    "@cdktf/hcl2json": "^0.20.0"
  },
  "devDependencies": {
    "@blueprint/config": "workspace:*",
    "@fast-check/vitest": "^0.1.3",
    "@types/node": "^20.14.0",
    "fast-check": "^3.23.1",
    "rimraf": "^6.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
