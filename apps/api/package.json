{
  "name": "@blueprint/api",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Cloud Infra Blueprint backend - NestJS + Fastify + Prisma + Postgres + Yjs WebSocket gateway.",
  "type": "commonjs",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:prod": "cross-env NODE_ENV=production node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "prisma generate",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "db:seed": "node -r @swc-node/register prisma/seed.ts",
    "clean": "rimraf dist .turbo"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.runtime.json prisma/seed.ts"
  },
  "dependencies": {
    "@blueprint/hcl": "workspace:*",
    "@blueprint/ir": "workspace:*",
    "@blueprint/resources": "workspace:*",
    "@blueprint/templates": "workspace:*",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@gitbeaker/rest": "^40.5.0",
    "@nestjs/common": "^10.4.6",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.6",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-fastify": "^10.4.6",
    "@nestjs/throttler": "^6.2.1",
    "@nestjs/websockets": "^10.4.6",
    "@octokit/rest": "^21.0.2",
    "@prisma/client": "^5.21.1",
    "bullmq": "^5.21.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "jszip": "^3.10.1",
    "nanoid": "^5.0.7",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "ws": "^8.18.0",
    "y-websocket": "^2.0.4",
    "yjs": "^13.6.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@blueprint/config": "workspace:*",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/testing": "^10.4.6",
    "@swc-node/register": "^1.11.1",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.13",
    "cross-env": "^7.0.3",
    "prisma": "^5.21.1",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.4"
  }
}
