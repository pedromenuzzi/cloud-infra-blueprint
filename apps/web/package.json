{
  "name": "@blueprint/web",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "Cloud Infra Blueprint web app — visual canvas + Monaco editor.",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test --config playwright.smoke.config.ts",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@blueprint/hcl": "workspace:*",
    "@blueprint/ir": "workspace:*",
    "@blueprint/resources": "workspace:*",
    "@blueprint/templates": "workspace:*",
    "@blueprint/ui": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hookform/resolvers": "^3.9.1",
    "@monaco-editor/react": "^4.6.0",
    "@xyflow/react": "^12.3.5",
    "dagre": "^0.8.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.453.0",
    "lz-string": "^1.5.0",
    "monaco-editor": "^0.52.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-resizable-panels": "^2.1.7",
    "react-router-dom": "^6.27.0",
    "y-monaco": "^0.1.6",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@blueprint/config": "workspace:*",
    "@playwright/test": "^1.48.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^15.11.7",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vite-plugin-wasm": "^3.3.0",
    "vitest": "^2.1.4"
  }
}
